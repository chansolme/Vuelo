# ── WhatsApp Cloud API (Meta Developer Portal) ───────────────────
WA_VERIFY_TOKEN=elige-una-frase-secreta-cualquiera
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxx
WA_PHONE_NUMBER_ID=1234567890

# ── Teléfono del dueño (número que recibe notificaciones y usa comandos)
# Formato: código de país + número, sin + ni espacios. Ej: Chile → 569XXXXXXXX
OWNER_PHONE=569XXXXXXXX

# ── Datos bancarios para transferencias ──────────────────────────
BANK_NAME=Santander
BANK_ACCOUNT_TYPE=Cuenta Corriente
BANK_ACCOUNT=000000000
BANK_RUT=00.000.000-0
BANK_HOLDER=Nombre del titular
BANK_EMAIL=correo@ejemplo.cl

# ── Upstash Redis (upstash.com → crear database gratis) ──────────
UPSTASH_REDIS_REST_URL=https://xxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxx

# ── Google Sheets ─────────────────────────────────────────────────
# ID de la planilla: extraer de la URL
# https://docs.google.com/spreadsheets/d/[ESTE_ID]/edit
GOOGLE_SHEET_ID=1BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxT
# JSON de la cuenta de servicio (todo en una sola línea)
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
